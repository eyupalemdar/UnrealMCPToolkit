    },
    {
      "capability": "blueprint_graph_editing",
      "mode": "builder_backed",
      "command_handlers": ["MCTBlueprintGraphCommands"],
      "builders": ["UMCTBlueprintGraphBuilder"],
      "exporters": [],
      "rationale": "K2 graph node, pin, variable, and graph mutations are reusable Blueprint builder operations."
    },
    {
      "capability": "blueprint_variables",
      "mode": "builder_backed",
      "command_handlers": ["MCTBlueprintGraphCommands"],
      "builders": ["UMCTBlueprintGraphBuilder"],
      "exporters": [],
      "rationale": "Blueprint member variable lifecycle is implemented by the graph builder."
