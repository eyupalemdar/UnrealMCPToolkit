    {
      "capability": "blueprint_parenting",
      "mode": "builder_backed",
      "command_handlers": ["MCTWidgetCommands"],
      "builders": ["UMCTWidgetBlueprintBuilder"],
      "exporters": [],
      "rationale": "Blueprint reparenting is an asset compatibility mutation handled by the Widget/Blueprint builder path."
