{
  "schema_version": 1,
  "server": "MCPToolkit",
  "description": "Builder/Exporter layering decisions for every capability in Resources/CapabilityMatrix.json. This file is intentionally explicit so new command families must declare whether domain logic stays command-owned, moves into Builders, or gets canonical Exporters coverage.",
  "coverage_policy": {
    "capabilities": "exactly_once"
  },
  "decisions": [
    {
      "capability": "utility_command_contract",
      "mode": "command_owned",
      "command_handlers": ["MCTUtilityCommands"],
      "builders": [],
      "exporters": [],
      "rationale": "Protocol, identity, and manifest commands are transport/control-plane concerns."
    },
    {
      "capability": "workflow_source_control_build_test",
      "mode": "command_owned",
      "command_handlers": ["MCTWorkflowCommands"],
      "builders": [],
      "exporters": [],
      "rationale": "Source control, logs, build, cook, and test commands orchestrate external workflows rather than Unreal asset construction."
    },
    {
      "capability": "project_introspection_and_plugins",
      "mode": "command_owned",
      "command_handlers": ["MCTProjectCommands"],
      "builders": [],
      "exporters": [],
      "rationale": "Project descriptor, plugin, and module operations are project-file orchestration."
    },
    {
      "capability": "project_config_mutation",
      "mode": "command_owned",
      "command_handlers": ["MCTProjectCommands"],
      "builders": [],
      "exporters": [],
      "rationale": "Config edits are structured .ini operations, not Unreal asset builder work."
    },
    {
      "capability": "async_task_queue",
      "mode": "command_owned",
      "command_handlers": ["MCTAsyncCommands"],
      "builders": [],
      "exporters": [],
      "rationale": "Async queue commands wrap command dispatch and event state."
    },
    {
      "capability": "export_introspection",
      "mode": "exporter_backed",
      "command_handlers": ["MCTExportCommands"],
      "builders": [],
      "exporters": [
        "UMCTWidgetBlueprintExporter",
        "UMCTAnimBlueprintExporter",
        "UMCTBlueprintExporter",
        "UMCTWorldExporter",
        "UMCTDataAssetExporter",
        "UMCTDataTableExporter",
        "UMCTInputExporter",
        "UMCTAudioExporter",
        "UMCTTextureExporter",
        "UMCTPhysicalMaterialExporter",
        "UMCTMaterialExporter"
      ],
      "rationale": "Canonical asset serialization is owned by registered Exporters and surfaced through export commands."
    },
    {
      "capability": "import_asset_files",
      "mode": "builder_backed",
      "command_handlers": ["MCTImportCommands"],
      "builders": ["UMCTAssetImportBuilder"],
      "exporters": [],
      "rationale": "External file ingestion creates persistent Unreal assets through reusable import builder logic."
    },
    {
      "capability": "runtime_diagnostics",
      "mode": "command_owned",
      "command_handlers": ["MCTRuntimeCommands"],
      "builders": [],
      "exporters": [],
      "rationale": "Runtime diagnostics are scoped read-only snapshots, not reusable asset authoring or canonical asset exports."
    },
    {
      "capability": "editor_world_console",
      "mode": "command_owned",
      "command_handlers": ["MCTEditorCommands"],
      "builders": [],
      "exporters": [],
      "rationale": "Editor world metadata and console execution operate on live editor state."
    },
    {
      "capability": "editor_actor_operations",
      "mode": "command_owned",
      "command_handlers": ["MCTEditorCommands"],
      "builders": [],
      "exporters": [],
      "rationale": "Actor spawn, transform, and delete mutate the live editor world rather than persistent asset definitions."
    },
    {
      "capability": "editor_level_operations",
      "mode": "command_owned",
      "command_handlers": ["MCTEditorCommands", "MCTLevelStructureCommands"],
      "builders": [],
      "exporters": [],
      "rationale": "Level lifecycle and level-structure diagnostics are editor/world operations."
    },
    {
      "capability": "editor_pie_control",
      "mode": "command_owned",
      "command_handlers": ["MCTEditorCommands"],
      "builders": [],
      "exporters": [],
      "rationale": "PIE lifecycle is editor session control."
    },
    {
      "capability": "editor_viewport_capture",
      "mode": "command_owned",
      "command_handlers": ["MCTEditorCommands"],
      "builders": [],
      "exporters": [],
      "rationale": "Viewport capture reads editor presentation state and writes image output."
    },
    {
      "capability": "widget_blueprint_authoring",
      "mode": "builder_backed",
      "command_handlers": ["MCTWidgetCommands"],
      "builders": ["UMCTWidgetBlueprintBuilder"],
      "exporters": [],
      "rationale": "Widget Blueprint tree creation and mutation belong in the reusable Widget builder."
    },
    {
      "capability": "widget_preview_capture",
      "mode": "command_owned",
      "command_handlers": ["MCTWidgetPreviewCommands"],
      "builders": [],
      "exporters": [],
