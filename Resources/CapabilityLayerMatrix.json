      "mode": "builder_backed",
      "command_handlers": ["MCTAssetCommands"],
      "builders": ["UMCTAssetFactory", "UMCTDataAssetBuilder"],
      "exporters": [],
      "rationale": "Generic asset creation and import-text property mutation use asset factory and data asset helpers; lifecycle operations remain command-owned inside this capability."
    },
    {
      "capability": "asset_lifecycle_reload",
      "mode": "command_owned",
